# Table registry (in-memory): server/src/game/table-registry.ts
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:3000
# Project URL (also used for JWKS verification when using JWT Signing Keys)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Legacy HS256 secret (Dashboard → Project Settings → JWT Keys → Legacy JWT Secret).
# Socket auth tries this first, then JWKS at SUPABASE_URL if verification still fails.
SUPABASE_JWT_SECRET=
