{
  "name": "poker-stud-server",
  "version": "1.0.0",
  "description": "Socket.IO server for Poker Stud game",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ./node_modules/typescript/lib/tsc.js",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "type-check": "node ./node_modules/typescript/lib/tsc.js --noEmit",
    "test:supabase": "tsx src/test-supabase.ts"
  },
  "dependencies": {
    "socket.io": "^4.8.1",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "@supabase/supabase-js": "^2.103.1",
    "jose": "^6.0.10",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "tsx": "^4.19.2"
  }
}
